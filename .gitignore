# Runtime artifacts (keep the directory in the Skill).
/skills/find-china-cdc-health-report/artifacts/*
!/skills/find-china-cdc-health-report/artifacts/.gitkeep

# Local release packages.
/dist/

# Task-local output and temporary files.
/work/
*.tmp
*.temp
*.log

# Python bytecode and caches.
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.hypothesis/

# Python virtual environments.
.venv/
venv/
env/
ENV/

# Test and coverage output.
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Build and packaging output.
build/
dist/
*.egg-info/
.eggs/

# Editors and IDEs.
.idea/
.vscode/
*.swp
*.swo
*~

# Operating-system metadata.
.DS_Store
Thumbs.db
